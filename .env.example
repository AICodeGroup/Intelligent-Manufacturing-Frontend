# Bailian / DashScope (OpenAI-compatible API)
# 每位开发者在本地复制为 .env.local 后填写自己的 Key，禁止提交真实密钥到仓库
BAILIAN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
BAILIAN_API_KEY=your-own-api-key
# 兼容命名（可二选一）
# DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
# DASHSCOPE_API_KEY=your-own-api-key
# 无本地 Key 时，可配置共享后端地址（示例：Vercel 线上域名）
# SHARED_AI_BASE_URL=https://your-project.vercel.app
BAILIAN_MODEL_QWEN=qwen3.5-plus
BAILIAN_MODEL_KIMI=kimi-k2.5


# 采购供应链助手使用本地市场爬虫，支持 Amazon、Google、Walmart、Target、eBay、淘宝、拼多多、京东等平台
